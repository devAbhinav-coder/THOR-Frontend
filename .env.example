NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
NEXT_PUBLIC_APP_NAME=The House of Rani
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics 4 (optional). Get ID from GA4 Admin → Data streams → Web → Measurement ID (G-XXXXXXXX).
# Consent Mode: denied by default in layout until user clicks “Accept all” in the cookie banner.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional Subresource Integrity (sha384-…) for third-party scripts. Run:
#   node scripts/compute-third-party-sri.mjs
# Copy hashes here when using a non-default GA ID or after Meta / Google rotate their assets.
NEXT_PUBLIC_GTAG_JS_INTEGRITY=
NEXT_PUBLIC_FB_EVENTS_JS_INTEGRITY=

# Cloudflare Turnstile (optional — pair with backend TURNSTILE_SECRET_KEY)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
