NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
NEXT_PUBLIC_APP_NAME=The House of Rani
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Meta Pixel (browser) — Events Manager → Data sources → your pixel → Settings → Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=
# Meta domain verification — Business Settings → Brand safety → Domains → Verify → Meta-tag method (content value only)
NEXT_PUBLIC_META_DOMAIN_VERIFICATION=

# Google Analytics 4 (optional). Get ID from GA4 Admin → Data streams → Web → Measurement ID (G-XXXXXXXX).
# Consent Mode: denied by default in layout until user clicks “Accept all” in the cookie banner.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Legacy alias still supported by the app if the variable above is empty:
NEXT_PUBLIC_GA_ID=

# Bing Webmaster Tools — paste the content value from msvalidate.01 meta tag verification.
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# IndexNow — generate a random key (e.g. 32 hex chars) in Bing Webmaster Tools → IndexNow.
# Serves https://yourdomain.com/{KEY}.txt and notifies Bing when products/blogs/categories update.
# Set the same value on frontend (middleware key file) and backend (URL submission).
INDEXNOW_API_KEY=
NEXT_PUBLIC_INDEXNOW_API_KEY=

# Optional Subresource Integrity (sha384-…) for third-party scripts. Run:
#   node scripts/compute-third-party-sri.mjs
# Copy hashes here when using a non-default GA ID or after Meta / Google rotate their assets.
NEXT_PUBLIC_GTAG_JS_INTEGRITY=
NEXT_PUBLIC_FB_EVENTS_JS_INTEGRITY=

# Cloudflare Turnstile (existing widget thehouseofrani — do not rotate)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAD8xzt2D6jkftCkc
